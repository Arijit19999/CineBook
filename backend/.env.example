# Copy to .env and fill in real values. .env is gitignored.
DATABASE_URL="postgresql://cinebook:cinebook@localhost:5432/cinebook?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-to-a-long-random-string"

# Groq (free tier, high limits) — get a key at https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Google Gemini (optional alternative) — https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

PORT=3000
NODE_ENV=development
